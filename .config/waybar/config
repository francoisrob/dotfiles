{
  "layer": "top",
  "position": "top",
  "exclusive": true,
  "modules-left": ["clock", "hyprland/workspaces", "hyprland/submap"],
  "modules-center": ["hyprland/window"],
  "modules-right": ["tray", "custom/mongodb", "cpu", "memory", "temperature", "pulseaudio", "backlight", "network", "custom/notification", "battery"],
  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "format": "<sub>{icon}</sub> {windows}",
    "window-rewrite-default": "",
    "format-window-separator": "  ",
    "window-rewrite": {
      "firefox": "",
      "kitty": "َ°†چ",
      "ghostty": "َ°†چ",
      "steam": "",
      "discord": "",
      "Chromium": "",
      "thunar": "",
      "spotify": "َ°“‡",
      "slack": "َ°’±",
      "stremio": ""
    },
    "persistent-workspaces": {
      "*": 3
    }
  },

  "tray": {
    "icon-size": 14,
    "spacing": 12,
    "reverse-direction": true
  },

  "backlight": {
    "format": "{icon} {percent}",
    "format-icons": [" َ°ƒ‍  ", " َ°ƒں  ", " َ°ƒ‌  ", " َ°ƒ  "],
    "tooltip": false
  },

  "clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>"
  },

  "network": {
    "format-wifi": " {essid}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}",
    "format-ethernet": "",
    "format-disconnected": ""
  },

  "pulseaudio": {
    "format": "{icon} {volume}",
    "format-bluetooth": " {icon} {volume}",
    "format-muted": " َ°‌ں ",
    "format-icons": {
      "headphones": "   ",
      "handsfree": "   ",
      "headset": "   ",
      "phone": "   ",
      "portable": "   ",
      "car": "   ",
      "default": ["  ", "  ", "   "]
    },
    "on-click": "pavucontrol"
  },

  "battery": {
    "interval": 60,
    "states": {
      "warning": 30,
      "critical": 20
    },
    "format": "{capacity}% {icon}",
    "format-icons": ["   ", "   ", "   ", "   ", "   "],
    "max-length": 25
  },

  "custom/notification": {
    "tooltip": false,
    "format": "{icon} {}",
    "format-icons": {
      "notification": " <span foreground='#fab387'><sup></sup></span>  ",
      "none": "   ",
      "dnd-notification": " <span foreground='#fab387'><sup></sup></span>  ",
      "dnd-none": "   ",
      "inhibited-notification": " <span foreground='#fab387'><sup></sup></span>  ",
      "inhibited-none": "   ",
      "dnd-inhibited-notification": " <span foreground='#fab387'><sup></sup></span>  ",
      "dnd-inhibited-none": "   "
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-middle": "swaync-client -C -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  "hyprland/submap": {
    "format": "{}",
    "max-length": 8,
    "tooltip": false
  },

  "cpu": {
    "interval": 5,
    "format": " {usage}%",
    "tooltip": true,
    "states": {
      "warning": 70,
      "critical": 90
    }
  },

  "memory": {
    "interval": 10,
    "format": " {used:0.1f}G",
    "tooltip-format": "{used:0.1f}G / {total:0.1f}G ({percentage}%)"
  },

  "temperature": {
    "interval": 5,
    "format": " {temperatureC}آ°C",
    "critical-threshold": 80,
    "format-critical": " {temperatureC}آ°C",
    "tooltip": false
  },

  "custom/mongodb": {
    "exec": "~/.config/waybar/scripts/mongodb-status.sh",
    "return-type": "json",
    "interval": 5,
    "format": "ًںچƒ {}",
    "on-click": "~/.config/waybar/scripts/mongodb-toggle.sh",
    "tooltip-format": "Click to toggle MongoDB"
  }
}
