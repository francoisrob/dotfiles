{
  "layer": "top",
  "position": "top",
  "exclusive": true,
  "modules-left": [
    "clock",
    "hyprland/workspaces",
    "hyprland/submap"
  ],
  "modules-center": [
    "hyprland/window"
  ],
  "modules-right": [
    "tray",
    "custom/mongodb",
    "mpris",
    "cpu",
    "memory",
    "temperature",
    "network",
    "custom/vpn",
    "pulseaudio",
    "backlight",
    "custom/notification",
    "battery"
  ],
  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "format": "<sub>{icon}</sub> {windows}",
    "window-rewrite-default": "´æä",
    "format-window-separator": "  ",
    "window-rewrite": {
      "firefox": "´ë®",
      "kitty": "¾░åı",
      "steam": "´åÂ",
      "discord": "´ç┐",
      "Chromium": "¯Øâ",
      "thunar": "¯½¼",
      "spotify": "¾░ôç",
      "slack": "¾░Æ▒",
      "stremio": "´öÇ"
    },
    "persistent-workspaces": {
      "*": 3
    }
  },
  "tray": {
    "icon-size": 14,
    "spacing": 12,
    "reverse-direction": true
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      " ¾░âŞ  ",
      " ¾░âş  ",
      " ¾░âØ  ",
      " ¾░âá "
    ],
    "tooltip": false
  },
  "clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>"
  },
  "network": {
    "format-wifi": "´ç½  {signalStrength}%",
    "format-ethernet": "´âü",
    "format-disconnected": "´äğ",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}/{cidr}",
    "tooltip-format-ethernet": "{ifname}\n{ipaddr}/{cidr}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 20,
    "on-click": "iwgtk"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": " {icon} {volume}%",
    "format-muted": " ¾░Øş ",
    "format-icons": {
      "headphones": " ´ÇÑ  ",
      "handsfree": " ´ûÉ  ",
      "headset": " ´ûÉ  ",
      "phone": " ´éò  ",
      "portable": " ´éò  ",
      "car": " ´éò  ",
      "default": [
        " ´ÇĞ ",
        " ´Çğ ",
        " ´Ç¿  "
      ]
    },
    "on-click": "pavucontrol"
  },
  "battery": {
    "interval": 60,
    "states": {
      "warning": 30,
      "critical": 20
    },
    "format": "{capacity}% {icon}",
    "format-icons": [
      " ´ëä  ",
      " ´ëâ  ",
      " ´ëâ  ",
      " ´ëü  ",
      " ´ëÇ  "
    ],
    "max-length": 25
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "¾░éÜ<span foreground='#fab387'><sup></sup></span>",
      "none": "¾░éÜ",
      "dnd-notification": "¾░éø<span foreground='#fab387'><sup></sup></span>",
      "dnd-none": "¾░éø",
      "inhibited-notification": "¾░éÜ<span foreground='#fab387'><sup></sup></span>",
      "inhibited-none": "¾░éÜ",
      "dnd-inhibited-notification": "¾░éø<span foreground='#fab387'><sup></sup></span>",
      "dnd-inhibited-none": "¾░éø"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-middle": "swaync-client -C -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "hyprland/submap": {
    "format": "{}",
    "max-length": 8,
    "tooltip": false
  },
  "cpu": {
    "interval": 5,
    "format": " {usage}%",
    "tooltip": true,
    "states": {
      "warning": 70,
      "critical": 90
    }
  },
  "memory": {
    "interval": 10,
    "format": " {used:0.1f}G",
    "tooltip-format": "{used:0.1f}G / {total:0.1f}G ({percentage}%)"
  },
  "temperature": {
    "interval": 5,
    "format": " {temperatureC}┬░C",
    "critical-threshold": 80,
    "format-critical": " {temperatureC}┬░C",
    "tooltip": false
  },
  "custom/mongodb": {
    "exec": "~/.config/waybar/scripts/mongodb-status.sh",
    "return-type": "json",
    "interval": 5,
    "format": "­şıâ {}",
    "on-click": "~/.config/waybar/scripts/mongodb-toggle.sh",
    "tooltip-format": "Click to toggle MongoDB"
  },
  "mpris": {
    "format": "{player_icon} {artist} - {title}",
    "format-paused": "{status_icon} {artist} - {title}",
    "player-icons": {
      "default": "¾░Éè",
      "spotify": "¾░│ç",
      "firefox": "¾░ê╣"
    },
    "status-icons": {
      "paused": "¾░Åñ"
    },
    "max-length": 30,
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  },
  "custom/vpn": {
    "exec": "~/.config/waybar/scripts/vpn-status.sh",
    "return-type": "json",
    "interval": 5,
    "format": "{icon}",
    "format-icons": {
      "connected": "¾░î¥",
      "disconnected": ""
    },
    "tooltip-format": "{}",
    "escape": true
  }
}
