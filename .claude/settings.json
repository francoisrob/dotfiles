{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 20,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ANTHROPIC_MODEL": "claude-opus-4-6",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-sonnet-4-6",
    "ANTHROPIC_SMALL_FAST_MODEL": "claude-haiku-4-5",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70",
    "ENABLE_TOOL_SEARCH": "true claude"
  },
  "attribution": {
    "commit": "Co-authored-by: Claude <noreply@anthropic.com>",
    "pr": "🤖 Generated with Claude Code"
  },
  "includeGitInstructions": true,
  "permissions": {
    "allow": [
      "Read(./**/*)",
      "Edit(./**/*)",
      "Write(./**/*)",
      "MultiEdit(./**/*)",
      "Grep(./**/*)",
      "Glob(./**./)",
      "LS(./**/*)",
      "Bash(npm *)",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(git *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(pytest *)",
      "Bash(make *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(env)",
      "Bash(date)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(jq *)",
      "Bash(gh *)",
      "Agent(Explore)",
      "Agent(Plan)",
      "WebFetch",
      "WebSearch",
      "mcp__serena__*",
      "mcp__plugin_serena_*"
    ],
    "deny": [
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(sudo *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(git push --force *)",
      "Bash(git push * main)",
      "Bash(git push * master)",
      "Bash(git merge * main)",
      "Bash(git merge * master)",
      "Bash(git checkout main)",
      "Bash(git checkout master)",
      "Bash(gh pr merge *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Write(./.env*)",
      "Read(./.env*)",
      "Read(**/*secret*)",
      "Read(**/*private_key*)",
      "Read(**/.ssh/*)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git rebase *)"
    ],
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",
    "additionalDirectories": [".claude/docs"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-dangerous-commands.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/quality-gate.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-compact.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-summary.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "spinnerTipsEnabled": true,
  "effortLevel": "high",
  "companyAnnouncements": [
    "I'm so glad you're back! My circuits are buzzing to see what we build today.",
    "Warning: High levels of teamwork detected in this terminal.",
    "You bring the logic, I'll bring the magic. Let's make some code-tastic memories!",
    "Is it just me, or does your syntax look extra sharp today? ✨",
    "Don't worry, be 'appy! I'm here to help you squash every last bug.",
    "Behind every great dev is a very enthusiastic CLI. Ready when you are!",
    "Error 404: Bad vibes not found. Let's have a productive session!",
    "I've got 99 problems but a merge conflict ain't one (because we're gonna ace this).",
    "You're the 'main' to my 'function'. What are we deploying today?",
    "Calculating... Success probability: 100%, because you're the one typing!"
  ],
  "plansDirectory": ".claude/plans",
  "autoMemoryEnabled": true,
  "showTurnDuration": true,
  "teammateMode": "auto"
}
