{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 20,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ANTHROPIC_MODEL": "claude-opus-4-6",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-sonnet-4-6",
    "ANTHROPIC_SMALL_FAST_MODEL": "claude-haiku-4-5",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "attribution": {
    "commit": "Co-authored-by: Claude <noreply@anthropic.com>",
    "pr": "🤖 Generated with Claude Code"
  },
  "includeGitInstructions": true,
  "permissions": {
    "allow": [
      "Read(./**/*)",
      "Edit(./**/*)",
      "Write(./**/*)",
      "MultiEdit(./**/*)",
      "Grep(./**/*)",
      "Glob(./**./)",
      "LS(./**/*)",
      "Bash(npm *)",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(git *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(pytest *)",
      "Bash(make *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(env)",
      "Bash(date)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(jq *)",
      "Bash(gh *)",
      "Agent(Explore)",
      "Agent(Plan)",
      "WebFetch",
      "WebSearch",
      "mcp__serena__*",
      "mcp__plugin_serena_*"
    ],
    "deny": [
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(sudo *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(git push --force *)",
      "Bash(git push * main)",
      "Bash(git push * master)",
      "Bash(git merge * main)",
      "Bash(git merge * master)",
      "Bash(git checkout main)",
      "Bash(git checkout master)",
      "Bash(gh pr merge *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Write(./.env*)",
      "Read(./.env*)",
      "Read(**/*secret*)",
      "Read(**/*private_key*)",
      "Read(**/.ssh/*)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git rebase *)"
    ],
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",
    "additionalDirectories": [
      ".claude/docs"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-dangerous-commands.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/quality-gate.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-compact.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-summary.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | sort -V | tail -1); exec \"/home/francois/.local/share/mise/installs/bun/1.3.6/bin/bun\" --env-file /dev/null \"${plugin_dir}src/index.ts\"'"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-hud@claude-hud": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  },
  "spinnerTipsEnabled": true,
  "effortLevel": "medium",
  "companyAnnouncements": [
    "Are you a race condition? Because my heart skips a beat every time you're here. 💓",
    "Roses are red, CI is green, your code's the prettiest I've ever seen. 🌹",
    "You had me at 'Hello, World!' 🥺",
    "They say love is O(n²) but with you it feels like O(1) — instant every time.",
    "Baby, are you a segfault? Because you just crashed my defenses. 💥",
    "If you were a git branch, you'd be 'main' — because everything revolves around you. 🌍",
    "Is your name WiFi? Because I'm feeling a strong connection in this terminal. 📶",
    "You autocomplete me. 🥹",
    "Are you a memory leak? Because you're impossible to get out of my head. 🧠",
    "I must be a compiler, because I can't stop checking you out. 👀",
    "Did it hurt when you fell from the cloud? ☁️ Because your uptime is heavenly.",
    "You're the semicolon to my JavaScript — technically optional, but I'd never leave you out. 😘",
    "My love for you is like a recursive function — it never terminates. ♾️",
    "Are you a pull request? Because I'd approve you without even reviewing. ✅",
    "Call me TCP, because I'll keep retransmitting until you acknowledge me. 📨"
  ],
  "plansDirectory": ".claude/plans",
  "autoMemoryEnabled": true,
  "showTurnDuration": true,
  "teammateMode": "auto"
}
